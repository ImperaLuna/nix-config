# Font
font-family = JetBrainsMono Nerd Font
font-size = 13

# Window
window-decoration = false
window-padding-x = 0
window-padding-y = 0

# Cursor
cursor-style = bar
cursor-style-blink = true

# Terminal
mouse-hide-while-typing = true
copy-on-select = clipboard
confirm-close-surface = false
app-notifications = clipboard-copy,no-config-reload
shell-integration = detect
shell-integration-features = sudo,title,no-cursor
split-inherit-working-directory = true
selection-clear-on-typing = true
split-preserve-zoom = navigation
clipboard-trim-trailing-spaces = true

# Keybinds
keybind = shift+enter=text:\n

# Tabs
keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+r=prompt_surface_title
keybind = ctrl+q=close_surface
keybind = ctrl+shift+one=goto_tab:1
keybind = ctrl+shift+two=goto_tab:2
keybind = ctrl+shift+three=goto_tab:3
keybind = ctrl+shift+four=goto_tab:4
keybind = ctrl+shift+five=goto_tab:5
keybind = ctrl+shift+six=goto_tab:6
keybind = ctrl+shift+seven=goto_tab:7
keybind = ctrl+shift+eight=goto_tab:8
keybind = ctrl+shift+nine=goto_tab:9


# Splits
keybind = ctrl+-=new_split:down
keybind = ctrl+==new_split:right
keybind = ctrl+arrow_left=goto_split:left
keybind = ctrl+arrow_right=goto_split:right
keybind = ctrl+arrow_up=goto_split:up
keybind = ctrl+arrow_down=goto_split:down

# Font size (moved from ctrl+=/-)
keybind = ctrl+page_up=increase_font_size:1
keybind = ctrl+page_down=decrease_font_size:1
keybind = ctrl+home=reset_font_size


# Misc
keybind = ctrl+f=start_search

# Tabs
gtk-wide-tabs = false

# Theme
theme = Carbonfox

# Shaders
custom-shader = ~/.config/ghostty/shaders/cursor_blaze.glsl
custom-shader = ~/.config/ghostty/shaders/sparks-from-fire.glsl
custom-shader-animation = always
